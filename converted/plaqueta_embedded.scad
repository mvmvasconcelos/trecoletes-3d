scale_z = orig_t == 0 ? 1 : thickness / orig_t;

center_x = (min_x + max_x)/2;
center_y = (min_y + max_y)/2;

// Modo de ancoragem: "center" coloca o centro XY em 0,0; "min" coloca o canto mínimo em 0,0
anchor = "center"; // opções: "center" | "min"

tx = anchor == "center" ? -center_x : -min_x;
ty = anchor == "center" ? -center_y : -min_y;
tz = -min_z; // sempre posicionar a base em Z=0

// Pré-transforma todos os pontos (escala + translação) para que o polyhedron fique já posicionado
transformed_points = [ for (p = points) [
  (p[0] + tx) * scale_xy,
  (p[1] + ty) * scale_xy,
  (p[2] + tz) * scale_z
] ];

polyhedron(points = transformed_points, faces = faces);

// Comentários de diagnóstico (valores calculados):
/* Valores (calculados automaticamente):
   original bbox X: [%g, %g]  center_x=%g  width=%g
   original bbox Y: [%g, %g]  center_y=%g  height=%g
   original bbox Z: [%g, %g]  thickness=%g
   scale_xy=%g  scale_z=%g
   anchor=%s
*/

// Marcador visual da origem (útil para ver onde 0,0 está)
if (show_origin) {
  color([1,0,0])
    translate([0,0,origin_marker_size/2])
      cube([origin_marker_size, origin_marker_size, origin_marker_size], center=true);
}

// -------- Texto paramétrico centralizado --------
// calcula altura do texto quando o parâmetro `text_height` for <= 0
auto_text_height = text_height <= 0 ? ((orig_h * scale_xy - 4) <= 0 ? max(1, orig_h * scale_xy * 0.5) : (orig_h * scale_xy - 4)) : text_height;

// monta string de fonte com estilo Bold se solicitado
font_arg = text_bold ? str(text_font, ":style=Bold") : text_font;

// Centro da placa nas coordenadas transformadas (onde queremos centralizar o texto)
transformed_center_x = (center_x + tx) * scale_xy;
transformed_center_y = (center_y + ty) * scale_xy;

// Renderiza o texto centralizado em X/Y sobre a face superior da placa
if (text != "") {
  color(text_color)
    translate([transformed_center_x, transformed_center_y, thickness])
      linear_extrude(height = text_thickness, center = false)
        text(text, size = auto_text_height, font = font_arg, halign = "center", valign = "center");
}

