{
    "id": "gerador_topo_bolo",
    "title": {
        "pt": "Topo de Bolo",
        "en": "Cake Topper"
    },
    "output_format": "3mf",
    "parts": [
        "base",
        "letters"
    ],
    "text_to_svg": false,
    "min_feature_size_mm": 0.8,
    "thin_wall_check": true,
    "parameters": [
        {
            "id": "text_line_1",
            "name": "Linha 1",
            "type": "text",
            "default": "Feliz",
            "placeholder": "Ex: Feliz"
        },
        {
            "id": "text_size_1",
            "name": "Tamanho da Linha 1",
            "type": "range",
            "min": 10,
            "max": 80,
            "step": 1,
            "default": 30,
            "unit": "mm"
        },
        {
            "id": "font_name",
            "name": "Fonte",
            "type": "select",
            "default": "Chewy:style=Regular",
            "options": [
                {
                    "value": "Chewy:style=Regular",
                    "label": "Chewy"
                },
                {
                    "value": "Leckerli One:style=Regular",
                    "label": "Leckerli One"
                },
                {
                    "value": "Pacifico:style=Regular",
                    "label": "Pacifico"
                }
            ]
        }
    ],
    "sections": [
        {
            "name": "Linha 2 (Opcional)",
            "collapsed": false,
            "parameters": [
                {
                    "id": "text_line_2",
                    "name": "Texto da Linha 2",
                    "type": "text",
                    "placeholder": "Ex: Aniversário",
                    "default": "Aniversário"
                },
                {
                    "id": "text_size_2",
                    "name": "Tamanho da Linha 2",
                    "type": "range",
                    "min": 10,
                    "max": 80,
                    "step": 1,
                    "default": 30,
                    "unit": "mm"
                }
            ]
        },
        {
            "name": "Aparência",
            "collapsed": false,
            "parameters": [
                {
                    "id": "text_boldness",
                    "name": "Espessura das letras",
                    "type": "range",
                    "min": 0,
                    "max": 5,
                    "step": 0.5,
                    "default": 1.5,
                    "unit": "mm"
                },
                {
                    "id": "outline_thickness",
                    "name": "Espessura do contorno",
                    "type": "range",
                    "min": 0.5,
                    "max": 8,
                    "step": 0.5,
                    "default": 3.0,
                    "unit": "mm"
                },
                {
                    "id": "line_gap",
                    "name": "Espaço entre linhas",
                    "type": "range",
                    "min": 0,
                    "max": 20,
                    "step": 1,
                    "default": 5,
                    "unit": "mm"
                },
                {
                    "id": "text_spacing",
                    "name": "Espaçamento das letras",
                    "type": "range",
                    "min": 0.5,
                    "max": 2.0,
                    "step": 0.05,
                    "default": 1.0
                }
            ]
        },
        {
            "name": "Alturas",
            "collapsed": true,
            "parameters": [
                {
                    "id": "base_height",
                    "name": "Altura do contorno e hastes",
                    "type": "range",
                    "min": 0.4,
                    "max": 5.0,
                    "step": 0.2,
                    "default": 1.6,
                    "unit": "mm"
                },
                {
                    "id": "letter_height",
                    "name": "Altura do relevo das letras",
                    "type": "range",
                    "min": 0.2,
                    "max": 3.0,
                    "step": 0.2,
                    "default": 0.8,
                    "unit": "mm"
                }
            ]
        },
        {
            "name": "Hastes",
            "collapsed": true,
            "parameters": [
                {
                    "id": "post_spacing",
                    "name": "Distância entre as hastes",
                    "type": "range",
                    "min": 20,
                    "max": 150,
                    "step": 5,
                    "default": 75,
                    "unit": "mm"
                },
                {
                    "id": "post_width",
                    "name": "Largura das hastes",
                    "type": "range",
                    "min": 2,
                    "max": 8,
                    "step": 0.5,
                    "default": 4,
                    "unit": "mm"
                },
                {
                    "id": "post_length",
                    "name": "Comprimento das hastes",
                    "type": "range",
                    "min": 0,
                    "max": 200,
                    "step": 5,
                    "default": 90,
                    "unit": "mm"
                }
            ]
        },
        {
            "name": "Cores",
            "parameters": [
                {
                    "id": "base_color",
                    "name": "Cor do Contorno e Hastes",
                    "type": "color",
                    "default": "#FFFFFF"
                },
                {
                    "id": "letters_color",
                    "name": "Cor das Letras",
                    "type": "color",
                    "default": "#FF0000"
                }
            ]
        }
    ]
}
