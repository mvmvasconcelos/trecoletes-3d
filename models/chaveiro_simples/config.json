{
    "id": "chaveiro_simples",
    "title": {
        "pt": "Chaveiro Simples",
        "en": "Simple Keychain"
    },
    "output_format": "3mf",
    "parts": [
        "base",
        "letters"
    ],
    "text_to_svg": true,
    "parameters": [
        {
            "id": "text_line_1",
            "name": "Nome",
            "type": "text",
            "default": "Verônica",
            "placeholder": "Ex: Verônica"
        },
        {
            "id": "font_name",
            "name": "Fonte",
            "type": "select",
            "default": "Chewy:style=Regular",
            "options": [
                {
                    "value": "Chewy:style=Regular",
                    "label": "Chewy"
                },
                {
                    "value": "Bangers:style=Regular",
                    "label": "Bangers"
                }
            ]
        }
    ],
    "sections": [
        {
            "name": "Dimensões e Contorno",
            "parameters": [
                {
                    "id": "text_size_1",
                    "name": "Tamanho do Texto",
                    "type": "range",
                    "min": 5,
                    "max": 50,
                    "step": 1,
                    "default": 12,
                    "unit": "mm"
                },
                {
                    "id": "base_height",
                    "name": "Espessura da Base",
                    "type": "range",
                    "min": 1,
                    "max": 10,
                    "step": 0.1,
                    "default": 2,
                    "unit": "mm"
                },
                {
                    "id": "letter_height",
                    "name": "Espessura do Relevo",
                    "type": "range",
                    "min": 0.1,
                    "max": 10,
                    "step": 0.1,
                    "default": 2,
                    "unit": "mm"
                },
                {
                    "id": "outline_margin",
                    "name": "Contorno Externo",
                    "type": "range",
                    "min": 0,
                    "max": 10,
                    "step": 0.1,
                    "default": 2.3,
                    "unit": "mm"
                },
                {
                    "id": "spacing",
                    "name": "Espaçamento das letras",
                    "type": "range",
                    "min": 0.5,
                    "max": 2.0,
                    "step": 0.05,
                    "default": 1.0
                },
                {
                    "id": "fill_letter_holes",
                    "name": "Preencher Furos (Letras O, A, P)",
                    "type": "checkbox",
                    "default": false
                }
            ]
        },
        {
            "name": "Furação",
            "parameters": [
                {
                    "id": "ring_outer_diameter",
                    "name": "Diâmetro Externo",
                    "type": "range",
                    "min": 2,
                    "max": 20,
                    "step": 0.1,
                    "default": 6,
                    "unit": "mm"
                },
                {
                    "id": "ring_inner_diameter",
                    "name": "Diâmetro Interno",
                    "type": "range",
                    "min": 1,
                    "max": 15,
                    "step": 0.1,
                    "default": 3,
                    "unit": "mm"
                },
                {
                    "id": "ring_offset_x",
                    "name": "Posição Horizontal",
                    "type": "range",
                    "min": -50,
                    "max": 50,
                    "step": 0.5,
                    "default": -1.0,
                    "unit": "mm"
                },
                {
                    "id": "ring_offset_y",
                    "name": "Posição Vertical",
                    "type": "range",
                    "min": -50,
                    "max": 50,
                    "step": 0.5,
                    "default": 6.0,
                    "unit": "mm"
                }
            ]
        },
        {
            "name": "Cores",
            "parameters": [
                {
                    "id": "base_color",
                    "name": "Cor da Base",
                    "type": "color",
                    "default": "#1B40D1"
                },
                {
                    "id": "letters_color",
                    "name": "Cor do Texto",
                    "type": "color",
                    "default": "#FFFFFF"
                }
            ]
        }
    ]
}
