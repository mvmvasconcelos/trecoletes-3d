{
    "id": "teste_tolerancia_texto",
    "title": {
        "pt": "Teste de Tolerância Texto",
        "en": "Text Tolerance Test"
    },
    "output_format": "3mf",
    "parts": [
        "chapa_negativa",
        "texto_positivo"
    ],
    "text_to_svg": false,
    "parameters": [
        {
            "id": "texto",
            "name": "Texto",
            "type": "text",
            "default": "TESTE"
        },
        {
            "id": "tamanho",
            "name": "Tamanho do Texto",
            "type": "range",
            "min": 5,
            "max": 50,
            "step": 1,
            "default": 10,
            "unit": "mm"
        },
        {
            "id": "tolerancias",
            "name": "Tolerâncias",
            "description": "Adicione uma tolerância por cavidade (mm). Cada cavidade acrescenta (largura_texto + 2×margem + tolerância) à largura da chapa.",
            "type": "holes_list",
            "default": [0.2, 0.4]
        },
        {
            "id": "margem",
            "name": "Margem",
            "description": "Espaço entre cada cavidade e as bordas da chapa (mm).",
            "type": "range",
            "default": 2,
            "min": 1,
            "max": 5,
            "step": 0.5,
            "unit": "mm"
        }
    ]
}