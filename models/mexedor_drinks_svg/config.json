                    "max": 5.0,
                    "step": 0.2,
                    "default": 0.8,
                    "unit": "mm",
                    "min_safe_mm": 0.4
                },
                {
                    "id": "letter_height",
                    "name": "Altura do relevo da arte",
                    "type": "range",
                    "min": 0.2,
                    "max": 3.0,
                    "step": 0.2,
                    "default": 0.8,
                    "unit": "mm",
                    "min_safe_mm": 0.4
                }
            ]
        },
        {
            "name": "Haste",
            "collapsed": true,
            "parameters": [
                {
                    "id": "post_x_offset",
                    "name": "Deslocamento horizontal da haste",
