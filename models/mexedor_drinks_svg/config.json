                    "type": "range",
                    "min": -150,
                    "max": 150,
                    "step": 1,
                    "default": 0,
                    "unit": "mm"
                },
                {
                    "id": "post_y_offset",
                    "name": "Deslocamento vertical da haste",
                    "help_text": "Move o ponto de conexão da haste para cima (positivo) ou para baixo (negativo)",
                    "type": "range",
                    "min": -100,
                    "max": 100,
                    "step": 1,
                    "default": 0,
                    "unit": "mm"
                },
                {
                    "id": "post_width",
                    "name": "Largura da haste",
                    "help_text": "Espessura da haste em milímetros",
                    "type": "range",
                    "min": 2,
                    "max": 8,
                    "step": 0.5,
                    "default": 4,
                    "unit": "mm"
                },
                {
                    "id": "post_length",
                    "name": "Comprimento da haste",
                    "help_text": "Quanto a haste fica abaixo da arte para mexer o drink",
                    "type": "range",
                    "min": 0,
                    "max": 200,
                    "step": 5,
                    "default": 120,
                    "unit": "mm"
                },
                {
                    "id": "tip_cylinder",
                    "name": "Cilindro na Ponta",
                    "help_text": "Adiciona um cilindro decorativo na extremidade inferior da haste.",
                    "type": "boolean",
                    "default": true
                },
                {
                    "id": "tip_diameter",
                    "name": "Diâmetro do Cilindro",
                    "help_text": "Diâmetro do cilindro na ponta da haste (mm). Fica dentro do comprimento da haste.",
