                    "type": "radio",
                    "default": "organic",
                    "options": [
                        { "value": "organic", "label": "Orgânico" },
                        { "value": "circle", "label": "Círculo" },
                        { "value": "square", "label": "Quadrado" }
                    ]
                },
                {
                    "id": "outline_thickness",
